@model InversionDetalleVm
@{ViewBag.Titulo=$"{Model.Inversion.Nombre} - Inversiones";var i=Model.Inversion;}
<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3"><div><a class="small text-decoration-none" asp-action="Index"><i class="bi bi-arrow-left"></i> Portafolio</a><h3 class="mb-1 mt-1"><span class="investment-icon me-2" style="color:@i.Color;background:color-mix(in srgb,@i.Color 14%,transparent)"><i class="bi @i.Icono"></i></span>@i.Nombre</h3><p class="text-muted mb-0">@i.TipoTexto@(string.IsNullOrWhiteSpace(i.Entidad)?"":" · "+i.Entidad)</p></div><div class="d-flex gap-2"><a class="btn btn-outline-primary btn-sm" asp-action="Tablero"><i class="bi bi-graph-up"></i> Analisis</a><form method="post" asp-action="CambiarEstado">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@i.Id"/><input type="hidden" name="estado" value="@(i.Estado=="activa"?"cerrada":"activa")"/><button class="btn @(i.Estado=="activa"?"btn-outline-warning":"btn-outline-success") btn-sm"><i class="bi @(i.Estado=="activa"?"bi-lock":"bi-arrow-repeat")"></i> @(i.Estado=="activa"?"Cerrar":"Reactivar")</button></form></div></div>
<div class="row g-2 mb-3"><div class="col-6 col-lg-3"><div class="mini-stat"><span>Valor actual</span><strong class="text-warning">@i.ValorActual.ToString("C0")</strong><small class="text-muted">@(i.FechaUltimaValoracion.HasValue?"Valorado "+i.FechaUltimaValoracion.Value.ToString("dd MMM"):"Valor contable")</small></div></div><div class="col-6 col-lg-3"><div class="mini-stat"><span>Capital aportado</span><strong>@i.CapitalAportado.ToString("C0")</strong></div></div><div class="col-6 col-lg-3"><div class="mini-stat"><span>Ganancia real</span><strong class="@(i.GananciaReal>=0?"text-success":"text-danger")">@i.GananciaReal.ToString("C0")</strong><small class="text-muted">@i.RentabilidadReal%</small></div></div><div class="col-6 col-lg-3"><div class="mini-stat"><span>Ganancia mensual esperada</span><strong class="text-success">@i.GananciaMensualEsperada.ToString("C0")</strong><small class="text-muted">@i.TasaMensualEquivalente.ToString("0.###")% equivalente</small></div></div></div>
<div class="row g-3 mb-3"><div class="col-12 col-lg-7"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-info-circle"></i> Condiciones</div><div class="card-body"><div class="investment-details"><span>Inicio<strong>@i.FechaInicio.ToString("dd MMM yyyy")</strong></span><span>Tasa pactada<strong>@i.Tasa.ToString("0.####")% @i.PeriodoTasa</strong></span><span>Equivalente anual<strong>@i.TasaAnualEquivalente.ToString("0.##")%</strong></span><span>Retorno esperado<strong>@(i.FechaRetorno?.ToString("dd MMM yyyy")??"Sin fecha")</strong></span><span>Permanencia minima<strong>@i.PermanenciaMeses meses</strong></span><span>Disponible desde<strong>@i.FechaDisponible.ToString("dd MMM yyyy")</strong></span><span>Penalidad retiro<strong>@(i.PenalidadRetiro.HasValue?i.PenalidadRetiro+"%":"No registrada")</strong></span><span>Proyeccion al retorno<strong>@i.ValorProyectadoRetorno.ToString("C0")</strong></span></div>@if(!string.IsNullOrWhiteSpace(i.Notas)){<hr/><p class="small text-muted mb-0">@i.Notas</p>}</div></div></div>
<div class="col-12 col-lg-5"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-lightning"></i> Registrar</div><div class="card-body"><div class="d-grid gap-2"><button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalMovimiento"><i class="bi bi-arrow-left-right"></i> Movimiento</button><button class="btn btn-premium" data-bs-toggle="modal" data-bs-target="#modalValoracion"><i class="bi bi-speedometer"></i> Actualizar valor de mercado</button></div>@if(i.EnPermanencia){<div class="investment-lock mt-3"><i class="bi bi-lock"></i> En permanencia hasta @i.FechaDisponible.ToString("dd MMM yyyy")</div>}<div class="small text-muted mt-3">Aportes y rendimientos aumentan el valor contable. Retiros y costos lo disminuyen. Una valoracion reemplaza el valor de mercado desde su fecha.</div></div></div></div></div>
<div class="row g-3"><div class="col-12 col-lg-7"><div class="card"><div class="card-header fw-bold"><i class="bi bi-clock-history"></i> Movimientos</div><div class="table-responsive"><table class="table mb-0 align-middle"><thead class="table-light"><tr><th>Fecha</th><th>Tipo</th><th class="text-end">Monto</th><th>Notas</th><th></th></tr></thead><tbody>@foreach(var m in Model.Movimientos){<tr><td>@m.Fecha.ToString("dd MMM yyyy")</td><td><span class="badge @(m.Tipo is "aporte" or "rendimiento"?"text-bg-success":"text-bg-warning")">@m.TipoTexto</span></td><td class="text-end fw-bold @(m.Tipo is "aporte" or "rendimiento"?"text-success":"text-danger")">@m.Monto.ToString("C0")</td><td class="text-muted small">@m.Notas</td><td><form method="post" asp-action="EliminarMovimiento" onsubmit="return confirm('Eliminar movimiento?')">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@m.Id"/><input type="hidden" name="inversionId" value="@i.Id"/><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></td></tr>}@if(!Model.Movimientos.Any()){<tr><td colspan="5" class="text-center text-muted py-4">Sin movimientos adicionales.</td></tr>}</tbody></table></div></div></div>
<div class="col-12 col-lg-5"><div class="card"><div class="card-header fw-bold"><i class="bi bi-speedometer"></i> Valoraciones</div><div class="list-group list-group-flush">@foreach(var v in Model.Valoraciones){<div class="list-group-item d-flex justify-content-between align-items-center"><span><strong>@v.Valor.ToString("C0")</strong><small class="d-block text-muted">@v.Fecha.ToString("dd MMM yyyy") · @v.Notas</small></span><form method="post" asp-action="EliminarValoracion">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@v.Id"/><input type="hidden" name="inversionId" value="@i.Id"/><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></div>}@if(!Model.Valoraciones.Any()){<div class="list-group-item text-center text-muted py-4">Sin valoraciones de mercado.</div>}</div></div></div></div>
<div class="modal fade" id="modalMovimiento"><div class="modal-dialog"><form class="modal-content" method="post" asp-action="RegistrarMovimiento">@Html.AntiForgeryToken()<input type="hidden" name="inversionId" value="@i.Id"/><div class="modal-header"><h5 class="modal-title">Registrar movimiento</h5><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-2 mb-3"><div class="col-6"><label class="form-label">Tipo</label><select name="tipo" id="inversionMovimientoTipo" class="form-select"><option value="aporte">Aporte adicional</option><option value="rendimiento">Rendimiento capitalizado</option><option value="retiro">Retiro</option><option value="costo">Costo / impuesto</option></select></div><div class="col-6"><label class="form-label">Fecha</label><input type="date" name="fecha" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required/></div></div><div class="mb-3"><label class="form-label">Monto</label><input type="number" name="monto" class="form-control" min="1" step=".01" required/></div><label class="form-label">Notas</label><input name="notas" class="form-control" maxlength="250"/></div><div class="modal-footer"><button class="btn btn-primary">Registrar</button></div></form></div></div>
<div class="modal fade" id="modalValoracion"><div class="modal-dialog"><form class="modal-content" method="post" asp-action="RegistrarValoracion">@Html.AntiForgeryToken()<input type="hidden" name="inversionId" value="@i.Id"/><div class="modal-header"><h5 class="modal-title">Valor de mercado</h5><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="row g-2 mb-3"><div class="col-6"><label class="form-label">Fecha</label><input type="date" name="fecha" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required/></div><div class="col-6"><label class="form-label">Valor total actual</label><input type="number" name="valor" class="form-control" min="0" step=".01" value="@i.ValorActual" required/></div></div><label class="form-label">Fuente / notas</label><input name="notas" class="form-control" maxlength="250" placeholder="Ej: extracto, precio de mercado"/></div><div class="modal-footer"><button class="btn btn-premium">Guardar valoracion</button></div></form></div></div>
<div class="mt-3 text-end"><form method="post" asp-action="Eliminar" onsubmit="return confirm('Eliminar esta inversion y todo su historial?')">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@i.Id"/><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Eliminar inversion</button></form></div>
@section Scripts{<script>
if(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Context.Request.Query["accion"].ToString()))==='rendimiento'){document.getElementById('inversionMovimientoTipo').value='rendimiento';new bootstrap.Modal(document.getElementById('modalMovimiento')).show();}
</script>}
