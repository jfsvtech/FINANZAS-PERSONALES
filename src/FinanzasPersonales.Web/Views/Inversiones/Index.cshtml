@model InversionesIndexVm
@inject PreferenciasUsuarioService Money
@{
    ViewBag.Titulo = "Inversiones - Finanzas Personales";
    string M(decimal valor, string moneda) => Money.FormatoMoneda(valor, moneda);
}
<div class="page-heading d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div><span class="page-eyebrow">Mi portafolio</span><h3 class="mb-1"><i class="bi bi-briefcase text-warning"></i> Inversiones</h3><p class="text-muted mb-0">Controla capital, rentabilidad, vencimientos y valor de mercado.</p></div>
    <div class="d-flex gap-2 flex-wrap"><a class="btn btn-outline-secondary btn-sm" asp-controller="TiposInversion" asp-action="Index"><i class="bi bi-tags"></i> Tipos</a><a class="btn btn-outline-primary btn-sm" asp-action="Tablero"><i class="bi bi-graph-up-arrow"></i> Analisis</a><button class="btn btn-premium btn-sm" onclick="abrirNueva()" @(Model.Tipos.Any(x=>x.Activo)?"":"disabled")><i class="bi bi-plus-lg"></i> Nueva inversion</button></div>
</div>
@if(!Model.Tipos.Any(x=>x.Activo)){<div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> Debes <a asp-controller="TiposInversion" asp-action="Index" class="alert-link">crear un tipo de inversion</a> antes de registrar una inversion.</div>}
<form method="get" class="card mb-3"><div class="card-body py-2"><div class="row g-2 align-items-end">
    <div class="col-6 col-md-3"><label class="form-label small mb-0">Estado</label><select name="estado" class="form-select form-select-sm"><option value="">Todas</option><option value="activa" selected="@(Model.FiltroEstado=="activa")">Activas</option><option value="cerrada" selected="@(Model.FiltroEstado=="cerrada")">Cerradas</option></select></div>
    <div class="col-6 col-md-4"><label class="form-label small mb-0">Tipo</label><select name="tipoId" class="form-select form-select-sm"><option value="">Todos</option>@foreach(var t in Model.Tipos){<option value="@t.Id" selected="@(Model.FiltroTipoId==t.Id)">@t.Nombre</option>}</select></div>
    <div class="col-6 col-md-2"><button class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-funnel"></i> Filtrar</button></div><div class="col-6 col-md-2"><a class="btn btn-outline-secondary btn-sm w-100" asp-action="Index">Limpiar</a></div>
</div></div></form>
<div class="row g-2 mb-3">
    <div class="col-6 col-lg-3"><div class="mini-stat"><span>Capital aportado</span><strong>@Model.TotalAportado.ToString("C0")</strong></div></div>
    <div class="col-6 col-lg-3"><div class="mini-stat"><span>Valor del portafolio</span><strong class="text-warning">@Model.ValorPortafolio.ToString("C0")</strong></div></div>
    <div class="col-6 col-lg-3"><div class="mini-stat"><span>Ganancia real</span><strong class="@(Model.GananciaTotal>=0?"text-success":"text-danger")">@Model.GananciaTotal.ToString("C0")</strong></div></div>
    <div class="col-6 col-lg-3"><div class="mini-stat"><span>Rentabilidad total</span><strong class="@(Model.RentabilidadTotal>=0?"text-success":"text-danger")">@Model.RentabilidadTotal%</strong></div></div>
</div>
@if(Model.Inversiones.Any()){
<div class="investment-grid">
@foreach(var i in Model.Inversiones){
    <div class="card investment-card @(i.Estado=="cerrada"?"investment-closed":"")" style="--investment-color:@i.Color">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-2"><span class="investment-icon" style="color:@i.Color;background:color-mix(in srgb,@i.Color 14%,transparent)"><i class="bi @i.Icono"></i></span><span class="badge @(i.Estado=="activa"?"text-bg-primary":"text-bg-secondary")">@i.Estado</span></div>
            <h5 class="mt-3 mb-0">@i.Nombre</h5><div class="text-muted small">@i.TipoTexto@(string.IsNullOrWhiteSpace(i.Entidad)?"":" · "+i.Entidad)</div>
            <div class="investment-value mt-3"><span>Valor actual</span><strong>@M(i.ValorActual, i.MonedaBaseCodigo)</strong></div>
            @if (i.MonedaCodigo != i.MonedaBaseCodigo) { <small class="text-muted">Capital original: @M(i.CapitalOriginal, i.MonedaCodigo) - tasa @i.TasaConversion.ToString("0.####")</small> }
            <div class="d-flex justify-content-between small mt-2"><span class="text-muted">Ganancia</span><strong class="@(i.GananciaReal>=0?"text-success":"text-danger")">@i.GananciaReal.ToString("C0") (@i.RentabilidadReal%)</strong></div>
            <div class="d-flex justify-content-between small mt-1"><span class="text-muted">Tasa</span><span>@i.Tasa.ToString("0.####")% @i.PeriodoTasa</span></div>
            @if(i.EnPermanencia){<div class="investment-lock mt-2"><i class="bi bi-lock"></i> Disponible desde @i.FechaDisponible.ToString("dd MMM yyyy")</div>}
            else if(i.FechaRetorno.HasValue){<div class="text-muted small mt-2"><i class="bi bi-calendar-event"></i> Retorno: @i.FechaRetorno.Value.ToString("dd MMM yyyy")</div>}
        </div>
        <div class="card-footer d-flex gap-2"><a class="btn btn-primary btn-sm flex-grow-1" asp-action="Detalle" asp-route-id="@i.Id"><i class="bi bi-clipboard-data"></i> Control</a><button class="btn btn-outline-secondary btn-sm" title="Editar" onclick='abrirEditar(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new{id=i.Id,nombre=i.Nombre,entidad=i.Entidad,tipoInversionId=i.TipoInversionId,fechaInicio=i.FechaInicio.ToString("yyyy-MM-dd"),capitalInicial=i.CapitalInicial,capitalOriginal=i.CapitalOriginal,monedaCodigo=i.MonedaCodigo,tasaConversion=i.TasaConversion,tasa=i.Tasa,periodoTasa=i.PeriodoTasa,tipoRendimiento=i.TipoRendimiento,fechaRetorno=i.FechaRetorno?.ToString("yyyy-MM-dd"),permanenciaMeses=i.PermanenciaMeses,penalidadRetiro=i.PenalidadRetiro,renovacionAutomatica=i.RenovacionAutomatica,color=i.Color,icono=i.Icono,notas=i.Notas})))'><i class="bi bi-pencil"></i></button></div>
    </div>
}
</div>
}else{<div class="empty-state"><i class="bi bi-briefcase"></i><strong>No tienes inversiones registradas</strong><div class="small mt-1">Crea la primera para comenzar a medir rentabilidad y vencimientos.</div><button class="btn btn-premium btn-sm mt-3" onclick="abrirNueva()">Crear inversion</button></div>}

<div class="modal fade" id="modalInversion" tabindex="-1"><div class="modal-dialog modal-lg"><form class="modal-content" method="post" asp-action="Guardar">@Html.AntiForgeryToken()<input type="hidden" name="id" id="invId" value="0"/><input type="hidden" name="icono" id="invIcono" value="bi-graph-up-arrow"/>
<div class="modal-header"><h5 class="modal-title" id="invTitulo">Nueva inversion</h5><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body">
    <div class="row g-2 mb-3"><div class="col-md-7"><label class="form-label">Nombre</label><input name="nombre" id="invNombre" class="form-control" maxlength="100" required placeholder="Ej: CDT Banco, Fondo conservador"/></div><div class="col-md-5"><label class="form-label">Entidad / plataforma</label><input name="entidad" id="invEntidad" class="form-control" maxlength="100"/></div></div>
    <div class="row g-2 mb-3"><div class="col-6 col-md-3"><label class="form-label">Tipo</label><select name="tipoInversionId" id="invTipo" class="form-select" required>@foreach(var t in Model.Tipos){<option value="@t.Id" data-color="@t.Color" data-icon="@t.Icono" data-activo="@t.Activo.ToString().ToLowerInvariant()">@t.Nombre@(t.Activo?"":" (inactivo)")</option>}</select></div><div class="col-6 col-md-3"><label class="form-label">Inicio</label><input type="date" name="fechaInicio" id="invFecha" class="form-control" required/></div><div class="col-6 col-md-3"><label class="form-label">Capital inicial</label><input type="number" name="capitalInicial" id="invCapital" class="form-control" min="1" step=".01" required/></div><div class="col-6 col-md-3"><label class="form-label">Rendimiento</label><select name="tipoRendimiento" id="invRendimiento" class="form-select"><option value="fijo">Fijo</option><option value="variable">Variable</option></select></div></div>
    <div class="row g-2 mb-3"><div class="col-6"><label class="form-label">Moneda</label><select name="monedaCodigo" id="invMoneda" class="form-select">@foreach(var m in Model.Monedas){if(m.Codigo==Model.MonedaBase){<option value="@m.Codigo" selected>@m.Codigo - @m.Nombre</option>}else{<option value="@m.Codigo">@m.Codigo - @m.Nombre</option>}}</select></div><div class="col-6"><label class="form-label">Tasa manual</label><input type="number" name="tasaConversion" id="invTasaConversion" class="form-control" min="0" step="0.000001" placeholder="Opcional"/></div></div>
    <div class="row g-2 mb-3"><div class="col-6 col-md-3"><label class="form-label">Tasa (%)</label><input type="number" name="tasa" id="invTasa" class="form-control" min="0" step=".0001" value="0" required/></div><div class="col-6 col-md-3"><label class="form-label">Periodo tasa</label><select name="periodoTasa" id="invPeriodo" class="form-select"><option value="anual">Anual</option><option value="mensual">Mensual</option></select></div><div class="col-6 col-md-3"><label class="form-label">Fecha retorno</label><input type="date" name="fechaRetorno" id="invRetorno" class="form-control"/></div><div class="col-6 col-md-3"><label class="form-label">Permanencia (meses)</label><input type="number" name="permanenciaMeses" id="invPermanencia" class="form-control" min="0" max="600" value="0"/></div></div>
    <div class="row g-2 mb-3"><div class="col-6 col-md-3"><label class="form-label">Penalidad retiro (%)</label><input type="number" name="penalidadRetiro" id="invPenalidad" class="form-control" min="0" max="100" step=".001"/></div><div class="col-6 col-md-3"><label class="form-label">Color</label><input type="color" name="color" id="invColor" class="form-control form-control-color w-100" value="#D4AF37"/></div><div class="col-12 col-md-6"><label class="form-label">Icono</label><div class="icon-picker investment-icon-picker">@foreach(var ic in new[]{"bi-graph-up-arrow","bi-bank","bi-piggy-bank","bi-bar-chart","bi-currency-bitcoin","bi-building","bi-globe2","bi-briefcase"}){<button type="button" class="icon-option" data-icon="@ic"><i class="bi @ic"></i></button>}</div></div></div>
    <div class="mb-3"><label class="form-label">Notas</label><textarea name="notas" id="invNotas" class="form-control" maxlength="500" rows="2"></textarea></div><div class="form-check"><input type="checkbox" name="renovacionAutomatica" id="invRenovacion" value="true" class="form-check-input"/><label class="form-check-label" for="invRenovacion">Renovacion automatica</label></div>
</div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-premium">Guardar inversion</button></div></form></div></div>
@section Scripts{<script>
const invModal=new bootstrap.Modal(document.getElementById('modalInversion'));
function seleccionarIcono(icono){document.getElementById('invIcono').value=icono;document.querySelectorAll('.investment-icon-picker .icon-option').forEach(x=>x.classList.toggle('selected',x.dataset.icon===icono));}
document.querySelectorAll('.investment-icon-picker .icon-option').forEach(x=>x.addEventListener('click',()=>seleccionarIcono(x.dataset.icon)));
function aplicarVisualTipo(){const o=document.getElementById('invTipo').selectedOptions[0];if(!o)return;document.getElementById('invColor').value=o.dataset.color||'#D4AF37';seleccionarIcono(o.dataset.icon||'bi-graph-up-arrow');}
document.getElementById('invTipo')?.addEventListener('change',aplicarVisualTipo);
function abrirNueva(){document.getElementById('invId').value=0;document.getElementById('invTitulo').textContent='Nueva inversion';document.getElementById('invNombre').value='';document.getElementById('invEntidad').value='';const tipo=document.getElementById('invTipo');const activo=[...tipo.options].findIndex(x=>x.dataset.activo==='true');tipo.selectedIndex=activo>=0?activo:0;document.getElementById('invFecha').value=new Date().toISOString().slice(0,10);document.getElementById('invCapital').value='';document.getElementById('invMoneda').value='@Model.MonedaBase';document.getElementById('invTasaConversion').value='';document.getElementById('invRendimiento').value='fijo';document.getElementById('invTasa').value=0;document.getElementById('invPeriodo').value='anual';document.getElementById('invRetorno').value='';document.getElementById('invPermanencia').value=0;document.getElementById('invPenalidad').value='';document.getElementById('invNotas').value='';document.getElementById('invRenovacion').checked=false;aplicarVisualTipo();invModal.show();}
function abrirEditar(x){document.getElementById('invId').value=x.id;document.getElementById('invTitulo').textContent='Editar inversion';document.getElementById('invNombre').value=x.nombre;document.getElementById('invEntidad').value=x.entidad||'';document.getElementById('invTipo').value=x.tipoInversionId;document.getElementById('invFecha').value=x.fechaInicio;document.getElementById('invCapital').value=x.capitalOriginal||x.capitalInicial;document.getElementById('invMoneda').value=x.monedaCodigo||'@Model.MonedaBase';document.getElementById('invTasaConversion').value=(x.tasaConversion&&x.tasaConversion!==1)?x.tasaConversion:'';document.getElementById('invRendimiento').value=x.tipoRendimiento;document.getElementById('invTasa').value=x.tasa;document.getElementById('invPeriodo').value=x.periodoTasa;document.getElementById('invRetorno').value=x.fechaRetorno||'';document.getElementById('invPermanencia').value=x.permanenciaMeses;document.getElementById('invPenalidad').value=x.penalidadRetiro||'';document.getElementById('invColor').value=x.color;document.getElementById('invNotas').value=x.notas||'';document.getElementById('invRenovacion').checked=x.renovacionAutomatica;seleccionarIcono(x.icono);invModal.show();}
if(@(Context.Request.Query["nuevo"]=="true"?"true":"false"))abrirNueva();
</script>}
