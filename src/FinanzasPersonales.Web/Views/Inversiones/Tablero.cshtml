@model InversionesTableroVm
@{ViewBag.Titulo="Analisis de inversiones";}
<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3"><div><span class="page-eyebrow">Vision del portafolio</span><h3 class="mb-1"><i class="bi bi-graph-up-arrow text-warning"></i> Analisis de inversiones</h3><p class="text-muted mb-0">Rentabilidad, diversificacion, liquidez y proximos eventos.</p></div><a class="btn btn-primary btn-sm" asp-action="Index"><i class="bi bi-briefcase"></i> Ver portafolio</a></div>
<div class="row g-2 mb-3"><div class="col-6 col-lg-2"><div class="mini-stat"><span>Inversiones</span><strong>@Model.Inversiones.Count(x=>x.Estado=="activa")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Aportado</span><strong>@Model.TotalAportado.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Valor actual</span><strong class="text-warning">@Model.ValorPortafolio.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Ganancia</span><strong class="@(Model.GananciaTotal>=0?"text-success":"text-danger")">@Model.GananciaTotal.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Rentabilidad</span><strong>@Model.RentabilidadTotal%</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Bloqueado</span><strong class="text-danger">@Model.LiquidezBloqueada.ToString("C0")</strong></div></div></div>
<div class="row g-3 mb-3"><div class="col-12 col-lg-5"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-pie-chart"></i> Distribucion por tipo</div><div class="card-body">@if(Model.Distribucion.Any()){<canvas id="invDistribucion"></canvas><div class="chart-category-legend mt-3">@foreach(var d in Model.Distribucion){<div class="chart-category-item"><span class="entity-icon" style="color:@d.Color;background:color-mix(in srgb,@d.Color 14%,transparent)"><i class="bi @d.Icono"></i></span><span><strong>@d.Nombre</strong><small>Diversificacion del portafolio</small></span><strong>@d.Total.ToString("C0")</strong></div>}</div>}else{<div class="empty-state"><i class="bi bi-pie-chart"></i>Sin inversiones.</div>}</div></div></div><div class="col-12 col-lg-7"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-activity"></i> Evolucion estimada del portafolio</div><div class="card-body"><canvas id="invEvolucion"></canvas></div></div></div></div>
<div class="row g-3"><div class="col-12 col-lg-5"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-calendar-event"></i> Proximos eventos</div><div class="list-group list-group-flush">@foreach(var i in Model.ProximosEventos){var fecha=i.FechaRetorno??i.FechaDisponible;<a class="list-group-item list-group-item-action d-flex align-items-center gap-2" asp-action="Detalle" asp-route-id="@i.Id"><span class="category-icon-sm" style="color:@i.Color"><i class="bi @i.Icono"></i></span><span class="flex-grow-1"><strong class="d-block">@i.Nombre</strong><small class="text-muted">@(i.FechaRetorno.HasValue?"Retorno esperado":"Fin permanencia") · @fecha.ToString("dd MMM yyyy")</small></span><i class="bi bi-chevron-right"></i></a>}@if(!Model.ProximosEventos.Any()){<div class="list-group-item text-muted text-center py-4">Sin vencimientos en los proximos 60 dias.</div>}</div></div></div><div class="col-12 col-lg-7"><div class="card h-100"><div class="card-header fw-bold"><i class="bi bi-stars"></i> Lectura financiera</div><div class="card-body"><div class="insight-card insight-info"><span class="alert-icon"><i class="bi bi-cash-coin"></i></span><span><strong>Ingreso mensual esperado</strong><small>Segun las tasas registradas: @Model.GananciaMensualEsperada.ToString("C0"). No sustituye la rentabilidad real de productos variables.</small></span></div>@if(Model.LiquidezBloqueada>0){<div class="insight-card insight-warning"><span class="alert-icon"><i class="bi bi-lock"></i></span><span><strong>Capital con permanencia minima</strong><small>@Model.LiquidezBloqueada.ToString("C0") no esta disponible sin considerar posibles penalidades.</small></span></div>}@if(Model.RentabilidadTotal<0){<div class="insight-card insight-danger"><span class="alert-icon"><i class="bi bi-graph-down-arrow"></i></span><span><strong>Portafolio con perdida no realizada</strong><small>Actualiza valoraciones y revisa costos antes de tomar decisiones.</small></span></div>}else if(Model.Inversiones.Any()){<div class="insight-card insight-success"><span class="alert-icon"><i class="bi bi-graph-up-arrow"></i></span><span><strong>Resultado positivo</strong><small>La rentabilidad consolidada registrada es @Model.RentabilidadTotal%.</small></span></div>}</div></div></div></div>
@section Scripts{<script>
const tc=themeColors(),dist=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Distribucion.Select(x=>new{nombre=x.Nombre,total=x.Total,color=x.Color}))),evo=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Evolucion.Select(x=>new{etiqueta=x.Etiqueta,valor=x.Valor})));
if(dist.length)new Chart(document.getElementById('invDistribucion'),{type:'doughnut',data:{labels:dist.map(x=>x.nombre),datasets:[{data:dist.map(x=>x.total),backgroundColor:dist.map(x=>x.color)}]},options:{plugins:{legend:{display:false}}}});
new Chart(document.getElementById('invEvolucion'),{type:'line',data:{labels:evo.map(x=>x.etiqueta),datasets:[{label:'Valor del portafolio',data:evo.map(x=>x.valor),borderColor:tc.gold,backgroundColor:'rgba(212,175,55,.14)',fill:true,tension:.3}]},options:{plugins:{legend:{display:false}},scales:{y:{ticks:{callback:v=>'$ '+v.toLocaleString('es-CO')}}}}});
</script>}
