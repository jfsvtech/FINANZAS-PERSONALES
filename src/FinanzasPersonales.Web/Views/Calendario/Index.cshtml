@model CalendarioFinancieroVm
@{
    ViewBag.Titulo = "Calendario financiero";
    var anterior = Model.PrimerDia.AddMonths(-1);
    var siguiente = Model.PrimerDia.AddMonths(1);
    var offset = ((int)Model.PrimerDia.DayOfWeek + 6) % 7;
    var eventosPorDia = Model.EventosMes.GroupBy(x => x.Fecha.Day).ToDictionary(x => x.Key, x => x.ToList());
}
<div class="page-heading d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3"><div><span class="page-eyebrow">Agenda unificada</span><h3 class="mb-1"><i class="bi bi-calendar3 text-warning"></i> Calendario financiero</h3><p class="text-muted mb-0">Tarjetas, gastos, cobros, metas y retornos en un solo lugar.</p></div><div class="btn-group"><a class="btn btn-outline-primary" asp-route-anio="@anterior.Year" asp-route-mes="@anterior.Month"><i class="bi bi-chevron-left"></i></a><span class="btn btn-primary text-capitalize" style="pointer-events:none">@Model.Periodo</span><a class="btn btn-outline-primary" asp-route-anio="@siguiente.Year" asp-route-mes="@siguiente.Month"><i class="bi bi-chevron-right"></i></a></div></div>
<div class="calendar-layout">
    <div class="card calendar-card"><div class="calendar-scroll"><div class="calendar-weekdays"><span>Lun</span><span>Mar</span><span>Mie</span><span>Jue</span><span>Vie</span><span>Sab</span><span>Dom</span></div><div class="calendar-grid">
        @for(var n=0;n<offset;n++){<div class="calendar-day calendar-empty"></div>}
        @for(var dia=1;dia<=Model.DiasMes;dia++){
            var fecha=new DateTime(Model.Anio,Model.Mes,dia);var esHoy=fecha==DateTime.Today;var eventos=eventosPorDia.GetValueOrDefault(dia)??new();
            <div class="calendar-day @(esHoy?"calendar-today":"")"><span class="calendar-number">@dia</span><div class="calendar-events">@foreach(var e in eventos.Take(3)){<a href="@e.Url" class="calendar-event" style="--event-color:@e.Color" title="@e.Titulo · @e.Detalle"><i class="bi @e.Icono"></i><span>@e.Titulo</span></a>}@if(eventos.Count>3){<span class="calendar-more">+@(eventos.Count-3) mas</span>}</div></div>
        }
    </div></div></div>
    <div class="card upcoming-card"><div class="card-header d-flex justify-content-between"><strong><i class="bi bi-bell"></i> Proximos 60 dias</strong><span class="badge text-bg-warning">@Model.ProximosEventos.Count</span></div><div class="list-group list-group-flush">@foreach(var e in Model.ProximosEventos){<div class="list-group-item calendar-upcoming"><span class="calendar-date"><strong>@e.Fecha.Day</strong><small>@e.Fecha.ToString("MMM")</small></span><span class="calendar-upcoming-icon" style="color:@e.Color;background:color-mix(in srgb,@e.Color 14%,transparent)"><i class="bi @e.Icono"></i></span><span class="flex-grow-1"><strong class="d-block">@e.Titulo</strong><small class="text-muted">@e.Detalle@if(e.Monto.HasValue){<text> · @e.Monto.Value.ToString("C0")</text>}</small></span><a class="btn btn-sm btn-outline-primary" href="@e.Url">@e.AccionTexto</a></div>}@if(!Model.ProximosEventos.Any()){<div class="list-group-item text-center text-muted py-5">No hay eventos durante los proximos 60 dias.</div>}</div></div>
</div>
