@model PersonaResumenVm
@{ViewBag.Titulo=$"Resumen de {Model.Persona.Nombre}";}
<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3"><div><a class="small text-decoration-none" asp-action="Index"><i class="bi bi-arrow-left"></i> Personas</a><h3 class="mb-1 mt-1"><i class="bi bi-person-vcard text-primary"></i> @Model.Persona.Nombre</h3><p class="text-muted mb-0">@Model.Persona.Telefono @if(!string.IsNullOrWhiteSpace(Model.Persona.Email)){<text> · @Model.Persona.Email</text>}</p></div><a class="btn btn-primary btn-sm" asp-controller="Prestamos" asp-action="Index" asp-route-personaId="@Model.Persona.Id" asp-route-nuevo="true"><i class="bi bi-plus-lg"></i> Nuevo prestamo</a></div>
<div class="row g-2 mb-3"><div class="col-6 col-lg-2"><div class="mini-stat"><span>Prestamos activos</span><strong>@Model.Prestamos.Count(x=>x.Estado=="activo")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Capital pendiente</span><strong class="text-primary">@Model.CapitalPendiente.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Interes pendiente</span><strong class="text-warning">@Model.InteresPendiente.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Total pagado</span><strong class="text-success">@Model.TotalPagado.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Capital pagado</span><strong>@Model.CapitalPagado.ToString("C0")</strong></div></div><div class="col-6 col-lg-2"><div class="mini-stat"><span>Proximo cobro</span><strong class="fs-6">@(Model.ProximaFechaCobro?.ToString("dd MMM yyyy")??"Sin fecha")</strong></div></div></div>
<div class="row g-3"><div class="col-12 col-lg-7"><div class="card"><div class="card-header fw-bold"><i class="bi bi-cash-stack"></i> Prestamos consolidados</div><div class="table-responsive"><table class="table align-middle mb-0"><thead class="table-light"><tr><th>Fecha</th><th>Estado</th><th class="text-end">Capital</th><th class="text-end">Saldo</th><th class="text-end">Interes pendiente</th><th></th></tr></thead><tbody>@foreach(var p in Model.Prestamos){<tr><td>@p.Fecha.ToString("dd MMM yyyy")</td><td><span class="badge @(p.Estado=="activo"?"text-bg-primary":"text-bg-success")">@p.Estado</span></td><td class="text-end">@p.Capital.ToString("C0")</td><td class="text-end fw-bold">@p.SaldoCapital.ToString("C0")</td><td class="text-end @(p.InteresPendiente>0?"text-warning":"text-success")">@p.InteresPendiente.ToString("C0")</td><td><a class="btn btn-sm btn-outline-primary" asp-controller="Prestamos" asp-action="Detalle" asp-route-id="@p.Id"><i class="bi bi-chevron-right"></i></a></td></tr>}@if(!Model.Prestamos.Any()){<tr><td colspan="6" class="text-center text-muted py-4">No hay prestamos registrados.</td></tr>}</tbody></table></div></div></div><div class="col-12 col-lg-5"><div class="card"><div class="card-header fw-bold"><i class="bi bi-clock-history"></i> Historial consolidado</div><div class="list-group list-group-flush persona-history">@foreach(var pago in Model.Pagos){<a class="list-group-item list-group-item-action d-flex align-items-center gap-2" asp-controller="Prestamos" asp-action="Detalle" asp-route-id="@pago.PrestamoId"><span class="category-icon-sm @(pago.Tipo=="abono_capital"?"text-success":"text-warning")"><i class="bi @(pago.Tipo=="abono_capital"?"bi-arrow-down-circle":"bi-percent")"></i></span><span class="flex-grow-1"><strong class="d-block">@pago.TipoTexto · @pago.Monto.ToString("C0")</strong><small class="text-muted">@pago.Fecha.ToString("dd MMM yyyy") · @pago.PrestamoReferencia</small></span><i class="bi bi-chevron-right"></i></a>}@if(!Model.Pagos.Any()){<div class="list-group-item text-center text-muted py-4">Sin pagos registrados.</div>}</div></div></div></div>
