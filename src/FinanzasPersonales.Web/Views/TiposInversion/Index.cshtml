@model List<TipoInversion>
@{ViewBag.Titulo="Tipos de inversion";}
<div class="page-heading d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3"><div><a class="small text-decoration-none" asp-controller="Inversiones" asp-action="Index"><i class="bi bi-arrow-left"></i> Portafolio</a><h3 class="mb-1 mt-1"><i class="bi bi-tags text-warning"></i> Tipos de inversion</h3><p class="text-muted mb-0">Cada usuario organiza el portafolio con sus propios tipos, colores e iconos.</p></div><button class="btn btn-premium btn-sm" onclick="abrirNuevo()"><i class="bi bi-plus-lg"></i> Nuevo tipo</button></div>
<div class="row g-3">@foreach(var t in Model){<div class="col-12 col-md-6 col-xl-4"><div class="card h-100 @(t.Activo?"":"investment-closed")"><div class="card-body d-flex align-items-center gap-3"><span class="investment-icon" style="color:@t.Color;background:color-mix(in srgb,@t.Color 14%,transparent)"><i class="bi @t.Icono"></i></span><span class="flex-grow-1"><strong class="d-block">@t.Nombre</strong><small class="text-muted">@t.CantidadInversiones inversion(es) · @(t.Activo?"Activo":"Inactivo")</small></span><button class="btn btn-sm btn-outline-secondary" onclick='abrirEditar(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(new{id=t.Id,nombre=t.Nombre,color=t.Color,icono=t.Icono,activo=t.Activo})))'><i class="bi bi-pencil"></i></button><form method="post" asp-action="Eliminar" onsubmit="return confirm('Eliminar este tipo?')">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@t.Id"/><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form></div></div></div>}@if(!Model.Any()){<div class="col-12"><div class="empty-state"><i class="bi bi-tags"></i>No tienes tipos de inversion.</div></div>}</div>
<div class="modal fade" id="modalTipo"><div class="modal-dialog"><form class="modal-content" method="post" asp-action="Guardar">@Html.AntiForgeryToken()<input type="hidden" name="id" id="tiId" value="0"/><input type="hidden" name="icono" id="tiIcono" value="bi-graph-up-arrow"/><div class="modal-header"><h5 class="modal-title" id="tiTitulo">Nuevo tipo</h5><button class="btn-close" type="button" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label class="form-label">Nombre</label><input name="nombre" id="tiNombre" class="form-control" maxlength="80" required placeholder="Ej: Renta fija, Crowdfunding"/></div><div class="mb-3"><label class="form-label">Color</label><input type="color" name="color" id="tiColor" class="form-control form-control-color w-100" value="#D4AF37"/></div><label class="form-label">Icono</label><div class="icon-picker tipo-icon-picker">@foreach(var ic in new[]{"bi-graph-up-arrow","bi-bank","bi-piggy-bank","bi-bar-chart","bi-currency-bitcoin","bi-building","bi-globe2","bi-briefcase","bi-gem","bi-safe"}){<button type="button" class="icon-option" data-icon="@ic"><i class="bi @ic"></i></button>}</div><div class="form-check mt-3"><input type="checkbox" name="activo" id="tiActivo" value="true" class="form-check-input" checked/><label class="form-check-label" for="tiActivo">Activo</label></div></div><div class="modal-footer"><button class="btn btn-premium">Guardar tipo</button></div></form></div></div>
@section Scripts{<script>
const tiModal=new bootstrap.Modal(document.getElementById('modalTipo'));function seleccionarTipoIcono(icono){document.getElementById('tiIcono').value=icono;document.querySelectorAll('.tipo-icon-picker .icon-option').forEach(x=>x.classList.toggle('selected',x.dataset.icon===icono));}document.querySelectorAll('.tipo-icon-picker .icon-option').forEach(x=>x.addEventListener('click',()=>seleccionarTipoIcono(x.dataset.icon)));
function abrirNuevo(){document.getElementById('tiId').value=0;document.getElementById('tiTitulo').textContent='Nuevo tipo';document.getElementById('tiNombre').value='';document.getElementById('tiColor').value='#D4AF37';document.getElementById('tiActivo').checked=true;seleccionarTipoIcono('bi-graph-up-arrow');tiModal.show();}
function abrirEditar(x){document.getElementById('tiId').value=x.id;document.getElementById('tiTitulo').textContent='Editar tipo';document.getElementById('tiNombre').value=x.nombre;document.getElementById('tiColor').value=x.color;document.getElementById('tiActivo').checked=x.activo;seleccionarTipoIcono(x.icono);tiModal.show();}
</script>}
