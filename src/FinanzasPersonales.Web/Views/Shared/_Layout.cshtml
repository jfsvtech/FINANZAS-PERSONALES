@{
    var controladorActual = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var esGastos = controladorActual is "Dashboard" or "Movimientos" or "Importar" or "Periodicos" or "Presupuestos";
    var esPrestamos = controladorActual is "Prestamos" or "Personas";
    var esInversiones = controladorActual is "Inversiones" or "TiposInversion";
    var autenticado = User.Identity?.IsAuthenticated == true;
    var claveTema = autenticado ? $"finanzas-tema-{User.Identity!.Name}" : "finanzas-tema-publico";
    var esAdmin = User.HasClaim("EsAdmin", "true");
    var puedeGastos = esAdmin || User.HasClaim("PermisoGastos", "true");
    var puedePrestamos = esAdmin || User.HasClaim("PermisoPrestamos", "true");
    var puedeInversiones = esAdmin || User.HasClaim("PermisoInversiones", "true");
    var puedeDirectivo = esAdmin || User.HasClaim("PermisoDirectivo", "true");
    var puedeAsistente = esAdmin || User.HasClaim("PermisoAsistente", "true");
    var puedeCalendario = esAdmin || User.HasClaim("PermisoCalendario", "true");
    var idiomaActual = User.FindFirst("Idioma")?.Value ?? "es";
    var monedaActual = User.FindFirst("MonedaCodigo")?.Value ?? "COP";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}
<!DOCTYPE html>
<html lang="@idiomaActual" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#7C3AED" />
    <title>@(ViewBag.Titulo ?? "Finanzas Personales")</title>
    <script>
        (() => {
            const key = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(claveTema));
            const saved = localStorage.getItem(key);
            document.documentElement.dataset.theme = saved || (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        })();
    </script>
    <link rel="manifest" href="~/manifest.json" />
    <link rel="apple-touch-icon" href="~/icono-192.png" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" asp-append-version="true" />
</head>
<body>
@if (autenticado)
{
    <aside class="app-sidebar">
        <a class="sidebar-brand" asp-controller="Inicio" asp-action="Index">
            <span class="brand-mark"><i class="bi bi-wallet2"></i></span>
            <span><strong>Finanzas</strong><small>Control personal</small></span>
        </a>
        <button class="sidebar-collapse-toggle" type="button" title="Comprimir menu">
            <i class="bi bi-layout-sidebar-inset"></i><span>Comprimir menu</span>
        </button>
        <nav class="sidebar-nav">
            <span class="sidebar-label">Principal</span>
            <a class="@(controladorActual == "Inicio" ? "active" : "")" asp-controller="Inicio" asp-action="Index"><i class="bi bi-grid-1x2"></i><span>Inicio</span></a>
            @if (!esAdmin) { <a class="@(controladorActual == "Documentacion" ? "active" : "")" asp-controller="Documentacion" asp-action="Index"><i class="bi bi-journal-bookmark"></i><span>Documentacion</span></a> }
            @if (puedeDirectivo) { <a class="@(controladorActual == "Directivo" ? "active premium-link" : "premium-link")" asp-controller="Directivo" asp-action="Index"><i class="bi bi-gem"></i><span>Analisis directivo</span></a> }
            @if (puedeAsistente) { <a class="@(controladorActual == "Asistente" ? "active premium-link" : "premium-link")" asp-controller="Asistente" asp-action="Index"><i class="bi bi-stars"></i><span>Asistente financiero</span></a> }
            @if (puedeCalendario) { <a class="@(controladorActual == "Calendario" ? "active premium-link" : "premium-link")" asp-controller="Calendario" asp-action="Index"><i class="bi bi-calendar3"></i><span>Calendario financiero</span></a> }

            @if (puedeGastos)
            {
            <div class="sidebar-group @(esGastos || controladorActual is "Metas" or "Cuentas" or "Categorias" || (controladorActual == "Asistente" && ViewContext.RouteData.Values["action"]?.ToString() == "Registro") ? "open" : "")" data-group="gastos">
                <button class="sidebar-group-toggle" type="button"><i class="bi bi-wallet2"></i><span>Gestion de Finanzas</span><i class="bi bi-chevron-down group-chevron"></i></button>
                <div class="sidebar-group-items">
                    <a class="@(controladorActual == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-bar-chart-line"></i><span>Analisis financiero</span></a>
                    <a class="@(controladorActual == "Asistente" && ViewContext.RouteData.Values["action"]?.ToString() == "Registro" ? "active premium-link" : "premium-link")" asp-controller="Asistente" asp-action="Registro"><i class="bi bi-mic"></i><span>Registro rapido</span></a>
                    <a class="@(controladorActual == "Movimientos" ? "active" : "")" asp-controller="Movimientos" asp-action="Index"><i class="bi bi-arrow-left-right"></i><span>Movimientos</span></a>
                    <a class="@(controladorActual == "Metas" ? "active premium-link" : "premium-link")" asp-controller="Metas" asp-action="Index"><i class="bi bi-flag"></i><span>Metas de ahorro</span></a>
                    <a class="@(controladorActual == "Periodicos" ? "active" : "")" asp-controller="Periodicos" asp-action="Index"><i class="bi bi-arrow-repeat"></i><span>Recurrentes</span></a>
                    <a class="@(controladorActual == "Presupuestos" ? "active" : "")" asp-controller="Presupuestos" asp-action="Index"><i class="bi bi-bullseye"></i><span>Presupuestos</span></a>
                    <a class="@(controladorActual == "Importar" ? "active" : "")" asp-controller="Importar" asp-action="Index"><i class="bi bi-upload"></i><span>Importar</span></a>
                    <a class="@(controladorActual == "Cuentas" ? "active" : "")" asp-controller="Cuentas" asp-action="Index"><i class="bi bi-bank"></i><span>Cuentas</span></a>
                    <a class="@(controladorActual == "Categorias" ? "active" : "")" asp-controller="Categorias" asp-action="Index"><i class="bi bi-tags"></i><span>Categorias</span></a>
                </div>
            </div>
            }

            @if (puedePrestamos)
            {
            <div class="sidebar-group @(esPrestamos ? "open" : "")" data-group="prestamos">
                <button class="sidebar-group-toggle" type="button"><i class="bi bi-cash-stack"></i><span>Gestion de Prestamos</span><i class="bi bi-chevron-down group-chevron"></i></button>
                <div class="sidebar-group-items">
                    <a class="@(controladorActual == "Prestamos" && ViewContext.RouteData.Values["action"]?.ToString() == "Tablero" ? "active" : "")" asp-controller="Prestamos" asp-action="Tablero"><i class="bi bi-graph-up-arrow"></i><span>Analisis de prestamos</span></a>
                    <a class="@(controladorActual == "Prestamos" && ViewContext.RouteData.Values["action"]?.ToString() != "Tablero" ? "active" : "")" asp-controller="Prestamos" asp-action="Index"><i class="bi bi-cash-stack"></i><span>Prestamos</span></a>
                    <a class="@(controladorActual == "Personas" ? "active" : "")" asp-controller="Personas" asp-action="Index"><i class="bi bi-person-rolodex"></i><span>Personas</span></a>
                </div>
            </div>
            }

            @if (puedeInversiones)
            {
            <div class="sidebar-group @(esInversiones ? "open" : "")" data-group="inversiones">
                <button class="sidebar-group-toggle" type="button"><i class="bi bi-briefcase"></i><span>Gestion de Inversiones</span><i class="bi bi-chevron-down group-chevron"></i></button>
                <div class="sidebar-group-items">
                    <a class="@(esInversiones && ViewContext.RouteData.Values["action"]?.ToString() == "Tablero" ? "active premium-link" : "premium-link")" asp-controller="Inversiones" asp-action="Tablero"><i class="bi bi-graph-up-arrow"></i><span>Analisis de inversiones</span></a>
                    <a class="@(controladorActual == "Inversiones" && ViewContext.RouteData.Values["action"]?.ToString() != "Tablero" ? "active" : "")" asp-controller="Inversiones" asp-action="Index"><i class="bi bi-briefcase"></i><span>Portafolio</span></a>
                    <a class="@(controladorActual == "TiposInversion" ? "active" : "")" asp-controller="TiposInversion" asp-action="Index"><i class="bi bi-tags"></i><span>Tipos de inversion</span></a>
                </div>
            </div>
            }

            @if (esAdmin)
            {
                <div class="sidebar-group @(controladorActual is "Usuarios" or "Configuracion" or "Documentacion" ? "open" : "")" data-group="administracion">
                    <button class="sidebar-group-toggle" type="button"><i class="bi bi-shield-lock"></i><span>Administracion</span><i class="bi bi-chevron-down group-chevron"></i></button>
                    <div class="sidebar-group-items"><a class="@(controladorActual == "Usuarios" ? "active" : "")" asp-controller="Usuarios" asp-action="Index"><i class="bi bi-people"></i><span>Usuarios</span></a><a class="@(controladorActual == "Configuracion" ? "active" : "")" asp-controller="Configuracion" asp-action="Integraciones"><i class="bi bi-plug"></i><span>Integraciones</span></a><a class="@(controladorActual == "Documentacion" ? "active" : "")" asp-controller="Documentacion" asp-action="Index"><i class="bi bi-journal-bookmark"></i><span>Documentacion</span></a></div>
                </div>
            }
        </nav>
        <div class="sidebar-premium">
            <i class="bi bi-stars"></i>
            <span><strong>Tu progreso importa</strong><small>Revisa tus metas cada mes.</small></span>
        </div>
    </aside>

    <header class="app-topbar">
        <button class="icon-button sidebar-toggle" type="button" data-bs-toggle="offcanvas" data-bs-target="#menuMovil"><i class="bi bi-list"></i></button>
        <div class="topbar-search">
            <i class="bi bi-search"></i>
            <input id="busquedaMenu" placeholder="Buscar una opcion..." autocomplete="off" />
            <div id="resultadosBusqueda" class="search-results d-none"></div>
        </div>
        <div class="topbar-actions">
            @if (puedeCalendario) { <a class="icon-button position-relative" asp-controller="Calendario" asp-action="Index" title="Calendario y vencimientos"><i class="bi bi-bell"></i><span class="notification-dot"></span></a> }
            @if (puedeGastos) { <a class="quick-register" asp-controller="Movimientos" asp-action="Index" asp-route-nuevo="true"><i class="bi bi-plus-lg"></i><span>Registrar</span></a> }
            <button class="icon-button theme-toggle" type="button" title="Cambiar tema"><i class="bi bi-moon-stars"></i></button>
            <div class="dropdown">
                <button class="user-menu" data-bs-toggle="dropdown"><span class="user-avatar">@User.Identity!.Name![0]</span><span class="user-copy"><strong>@User.Identity.Name</strong><small>Mi cuenta</small></span><i class="bi bi-chevron-down"></i></button>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#modalPreferencias"><i class="bi bi-translate"></i> Preferencias</a></li>
                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#modalCambiarClave"><i class="bi bi-key"></i> Cambiar clave</a></li>
                    @if (esAdmin) { <li><a class="dropdown-item" asp-controller="Configuracion" asp-action="Integraciones"><i class="bi bi-plug"></i> Integraciones</a></li> }
                    <li><hr class="dropdown-divider" /></li>
                    <li><a class="dropdown-item text-danger" asp-controller="Acceso" asp-action="Salir"><i class="bi bi-box-arrow-right"></i> Salir</a></li>
                </ul>
            </div>
        </div>
    </header>

    <div class="offcanvas offcanvas-start mobile-menu" tabindex="-1" id="menuMovil">
        <div class="offcanvas-header"><span class="sidebar-brand"><span class="brand-mark"><i class="bi bi-wallet2"></i></span><strong>Finanzas</strong></span><button class="btn-close" data-bs-dismiss="offcanvas"></button></div>
        <div class="offcanvas-body"><nav class="sidebar-nav">
            <a asp-controller="Inicio" asp-action="Index"><i class="bi bi-grid-1x2"></i> Inicio</a>
            @if (!esAdmin) { <a asp-controller="Documentacion" asp-action="Index"><i class="bi bi-journal-bookmark"></i> Documentacion</a> }
            @if (puedeDirectivo) { <a asp-controller="Directivo" asp-action="Index"><i class="bi bi-gem"></i> Analisis directivo</a> }
            @if (puedeAsistente) { <a asp-controller="Asistente" asp-action="Index"><i class="bi bi-stars"></i> Asistente financiero</a> }
            @if (puedeCalendario) { <a asp-controller="Calendario" asp-action="Index"><i class="bi bi-calendar3"></i> Calendario financiero</a> }
            @if (puedeGastos)
            {
                <div class="sidebar-group open"><button class="sidebar-group-toggle" type="button"><i class="bi bi-wallet2"></i><span>Gestion de Finanzas</span><i class="bi bi-chevron-down group-chevron"></i></button><div class="sidebar-group-items"><a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-bar-chart-line"></i> Analisis financiero</a>@if (puedeAsistente) { <a asp-controller="Asistente" asp-action="Registro"><i class="bi bi-mic"></i> Registro rapido</a> }<a asp-controller="Movimientos" asp-action="Index"><i class="bi bi-arrow-left-right"></i> Movimientos</a><a asp-controller="Metas" asp-action="Index"><i class="bi bi-flag"></i> Metas de ahorro</a><a asp-controller="Periodicos" asp-action="Index"><i class="bi bi-arrow-repeat"></i> Recurrentes</a><a asp-controller="Presupuestos" asp-action="Index"><i class="bi bi-bullseye"></i> Presupuestos</a><a asp-controller="Cuentas" asp-action="Index"><i class="bi bi-bank"></i> Cuentas</a><a asp-controller="Categorias" asp-action="Index"><i class="bi bi-tags"></i> Categorias</a></div></div>
            }
            @if (puedePrestamos)
            {
                <div class="sidebar-group"><button class="sidebar-group-toggle" type="button"><i class="bi bi-cash-stack"></i><span>Gestion de Prestamos</span><i class="bi bi-chevron-down group-chevron"></i></button><div class="sidebar-group-items"><a asp-controller="Prestamos" asp-action="Tablero"><i class="bi bi-graph-up-arrow"></i> Analisis de prestamos</a><a asp-controller="Prestamos" asp-action="Index"><i class="bi bi-cash-stack"></i> Prestamos</a><a asp-controller="Personas" asp-action="Index"><i class="bi bi-person-rolodex"></i> Personas</a></div></div>
            }
            @if (puedeInversiones)
            {
                <div class="sidebar-group"><button class="sidebar-group-toggle" type="button"><i class="bi bi-briefcase"></i><span>Gestion de Inversiones</span><i class="bi bi-chevron-down group-chevron"></i></button><div class="sidebar-group-items"><a asp-controller="Inversiones" asp-action="Tablero"><i class="bi bi-graph-up-arrow"></i> Analisis de inversiones</a><a asp-controller="Inversiones" asp-action="Index"><i class="bi bi-briefcase"></i> Portafolio</a><a asp-controller="TiposInversion" asp-action="Index"><i class="bi bi-tags"></i> Tipos de inversion</a></div></div>
            }
        </nav></div>
    </div>

    <div class="modal fade" id="modalCambiarClave" tabindex="-1"><div class="modal-dialog"><form class="modal-content" asp-controller="Acceso" asp-action="CambiarClave" method="post">@Html.AntiForgeryToken()<div class="modal-header"><h5 class="modal-title">Cambiar contrasena</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label class="form-label">Contrasena actual</label><input type="password" name="claveActual" class="form-control" autocomplete="current-password" required /></div><div class="mb-3"><label class="form-label">Nueva contrasena</label><input type="password" name="claveNueva" class="form-control" minlength="12" autocomplete="new-password" required /></div><div class="mb-3"><label class="form-label">Confirmar nueva contrasena</label><input type="password" name="confirmarClave" class="form-control" minlength="12" autocomplete="new-password" required /></div><div class="password-policy"><span><i class="bi bi-check2-circle"></i> Minimo 12 caracteres</span><span><i class="bi bi-check2-circle"></i> Mayuscula, minuscula, numero y simbolo</span></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-primary">Guardar</button></div></form></div></div>
    <div class="modal fade" id="modalPreferencias" tabindex="-1"><div class="modal-dialog"><form class="modal-content" asp-controller="Acceso" asp-action="CambiarPreferencias" method="post">@Html.AntiForgeryToken()<input type="hidden" name="returnUrl" value="@returnUrl" /><div class="modal-header"><h5 class="modal-title">Preferencias</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label class="form-label">Idioma</label><select name="idioma" class="form-select"><option value="es" selected="@(idiomaActual == "es" ? "selected" : null)">Espanol</option><option value="en" selected="@(idiomaActual == "en" ? "selected" : null)">English</option><option value="pt" selected="@(idiomaActual == "pt" ? "selected" : null)">Portugues</option></select></div><div class="mb-3"><label class="form-label">Moneda base</label><select name="monedaCodigo" class="form-select"><option value="COP" selected="@(monedaActual == "COP" ? "selected" : null)">COP - Peso colombiano</option><option value="USD" selected="@(monedaActual == "USD" ? "selected" : null)">USD - US Dollar</option><option value="EUR" selected="@(monedaActual == "EUR" ? "selected" : null)">EUR - Euro</option><option value="BRL" selected="@(monedaActual == "BRL" ? "selected" : null)">BRL - Real brasileiro</option></select><div class="form-text">La moneda base define como se consolidan los nuevos registros y reportes preparados para multimoneda.</div></div></div><div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button><button class="btn btn-primary">Actualizar preferencias</button></div></form></div></div>
}

<main class="app-content @(!autenticado ? "public-content" : "")">
    @if (TempData["Ok"] != null) { <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> @TempData["Ok"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }
    @if (TempData["Error"] != null) { <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> @TempData["Error"]<button class="btn-close" data-bs-dismiss="alert"></button></div> }
    @RenderBody()
</main>

@if (autenticado)
{
    <nav class="mobile-bottom-nav">
        <a class="@(controladorActual == "Inicio" ? "active" : "")" asp-controller="Inicio" asp-action="Index"><i class="bi bi-house-door"></i><span>Inicio</span></a>
        @if (puedeGastos) { <a class="@(esGastos || controladorActual is "Metas" or "Cuentas" or "Categorias" ? "active" : "")" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-wallet2"></i><span>Finanzas</span></a> }
        @if (puedeGastos) { <a class="mobile-add" asp-controller="Movimientos" asp-action="Index" asp-route-nuevo="true"><i class="bi bi-plus-lg"></i><span>Registrar</span></a> }
        @if (puedePrestamos) { <a class="@(controladorActual == "Prestamos" ? "active" : "")" asp-controller="Prestamos" asp-action="Index"><i class="bi bi-cash-stack"></i><span>Prestamos</span></a> }
        <button type="button" data-bs-toggle="offcanvas" data-bs-target="#menuMovil"><i class="bi bi-grid"></i><span>Menu</span></button>
    </nav>
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
const themeKey=@Html.Raw(System.Text.Json.JsonSerializer.Serialize(claveTema));
const sidebarKey='finanzas-sidebar-collapsed';
const sidebarGroupsKey='finanzas-sidebar-groups';
function themeColors(){const dark=document.documentElement.dataset.theme==='dark';return{purple:'#7C3AED',purpleSoft:'#A78BFA',gold:'#D4AF37',goldSoft:'#F2C94C',success:'#2FBF71',danger:'#E15B64',text:dark?'#D1D5DB':'#6B7280',grid:dark?'rgba(255,255,255,.08)':'#E5E7EB'};}
function applyChartTheme(){if(!window.Chart)return;const c=themeColors();Chart.defaults.color=c.text;Chart.defaults.borderColor=c.grid;Chart.helpers.each(Chart.instances,x=>x.update());}
function setTheme(theme){document.documentElement.dataset.theme=theme;localStorage.setItem(themeKey,theme);document.querySelectorAll('.theme-toggle i').forEach(i=>i.className=theme==='dark'?'bi bi-sun':'bi bi-moon-stars');document.querySelector('meta[name="theme-color"]').content=theme==='dark'?'#17171C':'#7C3AED';applyChartTheme();}
document.querySelectorAll('.theme-toggle').forEach(b=>b.addEventListener('click',()=>setTheme(document.documentElement.dataset.theme==='dark'?'light':'dark')));setTheme(document.documentElement.dataset.theme);
function setSidebarCollapsed(collapsed){document.body.classList.toggle('sidebar-collapsed',collapsed);localStorage.setItem(sidebarKey,collapsed?'true':'false');document.querySelector('.sidebar-collapse-toggle span')?.replaceChildren(document.createTextNode(collapsed?'Expandir menu':'Comprimir menu'));}
setSidebarCollapsed(localStorage.getItem(sidebarKey)==='true');
document.querySelector('.sidebar-collapse-toggle')?.addEventListener('click',()=>setSidebarCollapsed(!document.body.classList.contains('sidebar-collapsed')));
const savedGroups=JSON.parse(localStorage.getItem(sidebarGroupsKey)||'{}');
document.querySelectorAll('.app-sidebar .sidebar-group[data-group]').forEach(group=>{if(savedGroups[group.dataset.group]!==undefined)group.classList.toggle('open',savedGroups[group.dataset.group]);});
document.querySelectorAll('.sidebar-group-toggle').forEach(btn=>btn.addEventListener('click',()=>{const group=btn.closest('.sidebar-group');group.classList.toggle('open');if(group.dataset.group){savedGroups[group.dataset.group]=group.classList.contains('open');localStorage.setItem(sidebarGroupsKey,JSON.stringify(savedGroups));}}));
document.querySelectorAll('.app-sidebar .sidebar-nav a,.app-sidebar .sidebar-group-toggle').forEach(x=>x.title=x.innerText.trim());
const menuItems=[...document.querySelectorAll('.app-sidebar .sidebar-nav a')].map(a=>({text:a.innerText.trim(),href:a.href,icon:a.querySelector('i')?.className||''}));
const search=document.getElementById('busquedaMenu'),results=document.getElementById('resultadosBusqueda');
search?.addEventListener('input',()=>{const q=search.value.trim().toLowerCase();if(!q){results.classList.add('d-none');return;}const found=menuItems.filter(x=>x.text.toLowerCase().includes(q)).slice(0,6);results.innerHTML=found.map(x=>`<a href="${x.href}"><i class="${x.icon}"></i>${x.text}</a>`).join('')||'<span>Sin resultados</span>';results.classList.remove('d-none');});
if('serviceWorker' in navigator)navigator.serviceWorker.register('/sw.js');
function initPasswordToggles(){
    document.querySelectorAll('input[type="password"]:not([data-password-toggle-ready])').forEach(input=>{
        input.dataset.passwordToggleReady='true';
        const wrapper=document.createElement('div');
        wrapper.className='password-toggle-wrap';
        input.parentNode.insertBefore(wrapper,input);
        wrapper.appendChild(input);
        const btn=document.createElement('button');
        btn.type='button';
        btn.className='password-toggle-btn';
        btn.setAttribute('aria-label','Mostrar contrasena');
        btn.innerHTML='<i class="bi bi-eye"></i>';
        btn.addEventListener('click',()=>{
            const visible=input.type==='text';
            input.type=visible?'password':'text';
            btn.setAttribute('aria-label',visible?'Mostrar contrasena':'Ocultar contrasena');
            btn.innerHTML=visible?'<i class="bi bi-eye"></i>':'<i class="bi bi-eye-slash"></i>';
            input.focus();
        });
        wrapper.appendChild(btn);
    });
}
function initNumberFormatting(){
    const moneyNames=['monto','capital','valor','saldo','precio','pago','abono'];
    const shouldFormat=input=>{
        const name=(input.name||input.id||'').toLowerCase();
        if(!name || name.includes('tasa') || name.includes('porcentaje') || name.includes('dia') || name.includes('dias') || name.includes('telefono') || name.includes('port'))return false;
        return moneyNames.some(x=>name.includes(x));
    };
    const clean=value=>{
        value=(value||'').toString().trim();
        if(!value)return '';
        const normalized=value.replace(/\s/g,'').replace(/\./g,'').replace(',', '.');
        const n=Number(normalized);
        return Number.isFinite(n)?String(Math.round(n)):value.replace(/[^\d-]/g,'');
    };
    const format=value=>{
        const raw=clean(value);
        if(raw==='' || raw==='-')return raw;
        const n=Number(raw);
        return Number.isFinite(n)?n.toLocaleString('es-CO'):value;
    };
    document.querySelectorAll('input[type="number"]:not([data-number-format-ready])').forEach(input=>{
        if(!shouldFormat(input))return;
        input.dataset.numberFormatReady='true';
        input.dataset.rawType='number';
        input.type='text';
        input.inputMode='numeric';
        input.autocomplete=input.autocomplete||'off';
        input.value=format(input.value);
        input.addEventListener('focus',()=>{input.value=clean(input.value);});
        input.addEventListener('blur',()=>{input.value=format(input.value);});
        input.addEventListener('input',()=>{input.value=input.value.replace(/[^\d.,-]/g,'');});
    });
    document.querySelectorAll('form').forEach(form=>{
        if(form.dataset.numberSubmitReady)return;
        form.dataset.numberSubmitReady='true';
        form.addEventListener('submit',()=>form.querySelectorAll('input[data-number-format-ready="true"]').forEach(input=>input.value=clean(input.value)));
    });
}
initPasswordToggles();
initNumberFormatting();
document.addEventListener('shown.bs.modal',()=>{initPasswordToggles();initNumberFormatting();});
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
