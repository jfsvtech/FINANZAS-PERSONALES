@model PrestamosIndexVm
@inject PreferenciasUsuarioService Money
@{
    ViewBag.Titulo = "Prestamos - Finanzas Personales";
    var hoy = DateTime.Today;
    var inicioAnio = new DateTime(hoy.Year, 1, 1);
    var inicioTresMeses = hoy.AddMonths(-3).Date;
    string F(DateTime fecha) => fecha.ToString("yyyy-MM-dd");
    string M(decimal valor, string moneda) => Money.FormatoMoneda(valor, moneda);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-cash-stack"></i> Prestamos</h4>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-primary btn-sm" asp-action="Tablero">
            <i class="bi bi-graph-up-arrow"></i> Tablero
        </a>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Personas" asp-action="Index">
            <i class="bi bi-person-rolodex"></i> Personas
        </a>
        <button class="btn btn-success btn-sm" onclick="abrirNuevo()" @(Model.Personas.Any() ? "" : "disabled")>
            <i class="bi bi-plus-lg"></i> Nuevo prestamo
        </button>
    </div>
</div>

@if (!Model.Personas.Any())
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Antes de registrar un prestamo debes
        <a asp-controller="Personas" asp-action="Index" class="alert-link">crear al menos una persona</a>.
    </div>
}

<form method="get" class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="d-flex gap-1 flex-wrap mb-2">
            <span class="text-muted small me-1 align-self-center"><i class="bi bi-lightning"></i> Rapido:</span>
            <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-desde="@F(inicioTresMeses)" asp-route-hasta="@F(hoy)"
               asp-route-personaId="@Model.FiltroPersonaId" asp-route-estado="@Model.FiltroEstado">Ultimos 3 meses</a>
            <a class="btn btn-sm btn-outline-primary" asp-action="Index" asp-route-desde="@F(inicioAnio)" asp-route-hasta="@F(hoy)"
               asp-route-personaId="@Model.FiltroPersonaId" asp-route-estado="@Model.FiltroEstado">Este a&ntilde;o</a>
            <a class="btn btn-sm btn-outline-secondary" asp-action="Index" asp-route-personaId="@Model.FiltroPersonaId"
               asp-route-estado="@Model.FiltroEstado">Todas las fechas</a>
        </div>
        <div class="row g-2 align-items-end">
            <div class="col-6 col-md-3">
                <label class="form-label small mb-0">Persona</label>
                <select name="personaId" class="form-select form-select-sm">
                    <option value="">Todas</option>
                    @foreach (var pe in Model.Personas)
                    {
                        if (Model.FiltroPersonaId == pe.Id) { <option value="@pe.Id" selected>@pe.Nombre</option> }
                        else { <option value="@pe.Id">@pe.Nombre</option> }
                    }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small mb-0">Estado</label>
                <select name="estado" class="form-select form-select-sm">
                    <option value="">Todos</option>
                    @if (Model.FiltroEstado == "activo") { <option value="activo" selected>Activos</option> } else { <option value="activo">Activos</option> }
                    @if (Model.FiltroEstado == "pagado") { <option value="pagado" selected>Pagados</option> } else { <option value="pagado">Pagados</option> }
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small mb-0">Prestado desde</label>
                <input type="date" name="desde" class="form-control form-control-sm" value="@(Model.FiltroDesde?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small mb-0">Prestado hasta</label>
                <input type="date" name="hasta" class="form-control form-control-sm" value="@(Model.FiltroHasta?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-6 col-md-2">
                <button class="btn btn-outline-primary btn-sm w-100" type="submit"><i class="bi bi-funnel"></i> Filtrar</button>
            </div>
            <div class="col-6 col-md-1">
                <a class="btn btn-outline-secondary btn-sm w-100" asp-action="Index" title="Limpiar filtros"><i class="bi bi-x-lg"></i></a>
            </div>
        </div>
    </div>
</form>

<div class="row g-2 mb-3 text-center">
    <div class="col-4"><div class="card border-0 shadow-sm"><div class="card-body py-2">
        <div class="small text-muted">Capital prestado (activos)</div>
        <div class="fw-bold">@Model.TotalPrestado.ToString("C0")</div>
    </div></div></div>
    <div class="col-4"><div class="card border-0 shadow-sm"><div class="card-body py-2">
        <div class="small text-muted">Saldo de capital por cobrar</div>
        <div class="fw-bold text-primary">@Model.TotalSaldoCapital.ToString("C0")</div>
    </div></div></div>
    <div class="col-4"><div class="card border-0 shadow-sm"><div class="card-body py-2">
        <div class="small text-muted">Interes pendiente</div>
        <div class="fw-bold text-warning">@Model.TotalInteresPendiente.ToString("C0")</div>
    </div></div></div>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Persona</th><th class="d-none d-md-table-cell">Fecha</th>
                    <th class="text-end">Capital</th><th class="text-end">Saldo</th>
                    <th class="d-none d-md-table-cell text-end">Tasa</th>
                    <th class="text-end">Interes pendiente</th><th>Estado</th><th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var p in Model.Prestamos)
            {
                <tr class="@(p.Estado == "pagado" ? "table-success" : "")">
                    <td><i class="bi bi-person-circle me-1"></i> @p.PersonaNombre</td>
                    <td class="d-none d-md-table-cell">@p.Fecha.ToString("dd MMM yyyy")</td>
                    <td class="text-end">@M(p.CapitalOriginal ?? p.Capital, p.MonedaCodigo)@if(p.MonedaCodigo != Model.MonedaBase){<small class="d-block text-muted">@M(p.Capital, Model.MonedaBase)</small>}</td>
                    <td class="text-end fw-bold">@M(p.SaldoCapital, Model.MonedaBase)</td>
                    <td class="d-none d-md-table-cell text-end">@p.TasaMensual.ToString("0.##")%</td>
                    <td class="text-end fw-bold @(p.InteresPendiente > 0 ? "text-warning" : "text-success")">@p.InteresPendiente.ToString("C0")</td>
                    <td>
                        @if (p.Estado == "pagado") { <span class="badge text-bg-success">Pagado</span> }
                        else { <span class="badge text-bg-primary">Activo</span> }
                    </td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-primary" asp-action="Detalle" asp-route-id="@p.Id">
                            <i class="bi bi-clipboard-data"></i> Control
                        </a>
                    </td>
                </tr>
            }
            @if (!Model.Prestamos.Any())
            {
                <tr><td colspan="8" class="text-center text-muted py-4">No tienes prestamos registrados.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="modalPrestamo" tabindex="-1">
    <div class="modal-dialog">
        <form class="modal-content" method="post" asp-action="Guardar">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="0" />
            <div class="modal-header">
                <h5 class="modal-title">Nuevo prestamo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Persona</label>
                    <select name="personaId" class="form-select" required>
                        @foreach (var pe in Model.Personas) { <option value="@pe.Id">@pe.Nombre</option> }
                    </select>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label">Fecha del prestamo</label>
                        <input type="date" name="fecha" id="prFecha" class="form-control" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Capital</label>
                        <input type="number" name="capital" id="prCapital" class="form-control" min="1" step="1"
                               inputmode="numeric" required oninput="calcularInteres()" />
                    </div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label">Moneda</label>
                        <select name="monedaCodigo" class="form-select">
                            @foreach (var moneda in Model.Monedas)
                            {
                                if (moneda.Codigo == Model.MonedaBase) { <option value="@moneda.Codigo" selected>@moneda.Codigo - @moneda.Nombre</option> }
                                else { <option value="@moneda.Codigo">@moneda.Codigo - @moneda.Nombre</option> }
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label">Tasa manual</label>
                        <input type="number" name="tasaConversion" class="form-control" min="0" step="0.000001" placeholder="Opcional" />
                    </div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label">Interes mensual (%)</label>
                        <input type="number" name="tasaMensual" id="prTasa" class="form-control" min="0" max="100"
                               step="0.1" inputmode="decimal" required oninput="calcularInteres()" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Interes mensual ($)</label>
                        <input id="prInteresCalc" class="form-control bg-light" readonly tabindex="-1" />
                    </div>
                </div>
                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label class="form-label">Dia de pago de interes</label>
                        <input type="number" name="diaPagoInteres" class="form-control" min="1" max="31"
                               inputmode="numeric" placeholder="Ej: 15" />
                    </div>
                    <div class="col-6">
                        <label class="form-label">Pago del capital (si aplica)</label>
                        <input type="date" name="fechaPagoCapital" class="form-control" />
                    </div>
                </div>
                <div class="mb-2">
                    <label class="form-label">Notas (opcional)</label>
                    <textarea name="notas" class="form-control" maxlength="300" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn btn-primary">Registrar prestamo</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    const modal = new bootstrap.Modal(document.getElementById('modalPrestamo'));

    function abrirNuevo() {
        document.getElementById('prFecha').value = new Date().toISOString().slice(0, 10);
        calcularInteres();
        modal.show();
    }
    function calcularInteres() {
        const capital = parseFloat(document.getElementById('prCapital').value) || 0;
        const tasa = parseFloat(document.getElementById('prTasa').value) || 0;
        document.getElementById('prInteresCalc').value =
            '$ ' + Math.round(capital * tasa / 100).toLocaleString('es-CO');
    }

    if (@(Context.Request.Query["nuevo"] == "true" && Model.Personas.Any() ? "true" : "false")) {
        abrirNuevo();
    }
</script>
}
