@{
    ViewBag.Titulo = "Recuperar contrasena - Finanzas Personales";
    Layout = "_Layout";
}
<div class="login-shell">
    <div class="col-12 col-sm-8 col-md-5 col-lg-4">
        <div class="card login-card">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <span class="login-brand"><i class="bi bi-shield-lock"></i></span>
                    <span class="page-eyebrow mt-3">Acceso seguro</span>
                    <h4 class="mt-1">Recuperar contrasena</h4>
                    <p class="text-muted small">Te enviaremos un enlace de un solo uso si el correo existe.</p>
                    <div class="btn-group btn-group-sm mt-2" role="group" aria-label="Idioma">
                        <a class="btn btn-outline-primary" asp-action="RecuperarClave" asp-route-lang="es">ES</a>
                        <a class="btn btn-outline-primary" asp-action="RecuperarClave" asp-route-lang="en">EN</a>
                        <a class="btn btn-outline-primary" asp-action="RecuperarClave" asp-route-lang="pt">PT</a>
                    </div>
                </div>
                <form method="post" asp-action="RecuperarClave">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label">Correo electronico</label>
                        <input name="email" type="email" class="form-control form-control-lg" autocomplete="email" required />
                    </div>
                    <button class="btn btn-primary btn-lg w-100" type="submit">
                        <i class="bi bi-envelope-check"></i> Enviar enlace
                    </button>
                </form>
                <a class="btn btn-secondary w-100 mt-2" asp-action="Login">Volver al ingreso</a>
                <button class="theme-toggle login-theme-toggle" type="button"><i class="bi bi-moon-stars"></i> Cambiar tema</button>
            </div>
        </div>
    </div>
</div>
