@model DocumentacionIndexVm
@{
    ViewBag.Titulo = "Documentacion";
}

<div class="page-heading d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
        <span class="page-eyebrow">Centro de ayuda</span>
        <h3 class="mb-1"><i class="bi bi-journal-bookmark text-warning"></i> Documentacion</h3>
        <p class="text-muted mb-0">Consulta guias funcionales, tecnicas y de despliegue segun tus permisos.</p>
    </div>
    @if (Model.EsAdmin)
    {
        <a class="btn btn-outline-primary btn-sm" asp-controller="Configuracion" asp-action="Integraciones">
            <i class="bi bi-plug"></i> Integraciones
        </a>
    }
</div>

<div class="row g-3 mb-4">
    @foreach (var doc in Model.Documentos)
    {
        <div class="col-12 col-lg-4">
            <div class="card h-100 integration-card">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <span class="integration-icon"><i class="bi @doc.Icono"></i></span>
                        <span class="badge @(doc.Nivel == "Administracion" ? "text-bg-warning" : "text-bg-primary")">@doc.Nivel</span>
                    </div>
                    <h5>@doc.Titulo</h5>
                    <p class="text-muted small flex-grow-1">@doc.Descripcion</p>
                    <div class="d-flex gap-2">
                        <a class="btn btn-primary flex-fill" asp-action="Ver" asp-route-id="@doc.Codigo">
                            <i class="bi bi-journal-text"></i> Ver en pantalla
                        </a>
                        <a class="btn btn-outline-primary" asp-action="Pdf" asp-route-id="@doc.Codigo" target="_blank" rel="noopener" title="Ver PDF">
                            <i class="bi bi-file-earmark-pdf"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
        <strong><i class="bi bi-list-check"></i> Guia funcional disponible para tu perfil</strong>
    </div>
    <div class="card-body">
        <div class="row g-3">
            @foreach (var seccion in Model.SeccionesFuncionales)
            {
                <div class="col-12 col-xl-6">
                    <div class="doc-section-card h-100">
                        <div class="doc-section-icon"><i class="bi @seccion.Icono"></i></div>
                        <div>
                            <h5>@seccion.Titulo</h5>
                            <p class="text-muted small mb-2">@seccion.Descripcion</p>
                            <ul class="small mb-0">
                                @foreach (var punto in seccion.Puntos)
                                {
                                    <li>@punto</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
